APP_NAME=store-intelligence
ENVIRONMENT=local
LOG_LEVEL=INFO

SIMULATION_MODE=true
REAL_PIPELINE_MODE=false

DATABASE_URL=postgresql+asyncpg://store_intel:store_intel@postgres:5432/store_intel
POSTGRES_DB=store_intel
POSTGRES_USER=store_intel
POSTGRES_PASSWORD=store_intel

REDIS_URL=redis://redis:6379/0
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b

DEFAULT_STORE_ID=00000000-0000-4000-8000-000000000001
EVENT_STALE_AFTER_SECONDS=90

